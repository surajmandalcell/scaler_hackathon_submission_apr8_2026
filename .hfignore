# Files to exclude from the HuggingFace Space upload.
# The .env file contains an HF token and must never be pushed.

.git
.venv
.env
.env.local
.env.*

# Python build artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.mypy_cache
.ruff_cache
.pytest_cache

# Node build artifacts
node_modules
packages/frontend/dist

# IDE / OS
.DS_Store
.vscode
.idea

# Claude workspace noise (not part of the submission)
.claude
.mcp.json

# Local Docker / dev state
*.log
fundlens.db
*.egg-info

# Legacy prior-iteration folder at the repo root (has its own Dockerfile,
# inference.py, openenv.yaml, sample .xlsx files). Not used by the runtime
# image -- the canonical backend lives in packages/backend/. Shipping this
# to HF Spaces would confuse `openenv validate` since it contains a second
# openenv.yaml with different version metadata.
/fundlens/

# ── Binary files ──────────────────────────────────────────────────────────
# Belt-and-suspenders: .gitignore already blocks these from ever being
# committed, but this list also covers the `huggingface_hub` upload path
# in case someone ever switches to the HF Python SDK instead of git push.
# HF Spaces rejects unversioned binaries over git and requires Xet LFS
# (https://huggingface.co/docs/hub/xet). We avoid the issue entirely by
# keeping the repo text-only.

*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.odt
*.ods

*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.bz2
*.xz
*.rar
*.7z

*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.ico
*.tif
*.tiff
*.webp
*.psd
*.ai
*.sketch
*.fig

*.mp3
*.mp4
*.mov
*.wav
*.avi
*.mkv
*.webm
*.flac
*.ogg

*.bin
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx
*.h5
*.pkl
